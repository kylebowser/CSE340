<h1><%= title %></h1>
<%- messages() %>
<% if (errors) { %>
  <ul class="notice">
 <% errors.array().forEach(error => { %>
   <li><%= error.msg %></li>
<%  }) %>
 </ul>
<% } %>
<form method="post" action="/account/signup" class="wf1">
  <fieldset>
    <label for="fname"
      >First Name<input
        type="text"
        name="account_firstname"
        id="fname"
        required
    /></label>
    <label for="lname"
      >Last Name<input
        type="text"
        name="account_lastname"
        id="account_lastname"
        required
    /></label>
    <label for="email"
      >Email<input
        type="email"
        name="account_email"
        id="email"
        placeholder="example@example.com"
        required
    /></label>
    <label for="accountPassword">Password:</label>
    <span
      >Passwords must be at least 12 characters and contain at least 1 number, 1
      capital letter and 1 special character</span
    >
    <input
      type="password"
      name="account_password"
      id="accountPassword"
      required
      pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!.*\s).{12,}$"
    />
    <label for="submit"
      ><input type="submit" id="submit" value="Sign-Up"
    /></label>
  </fieldset>
</form>
